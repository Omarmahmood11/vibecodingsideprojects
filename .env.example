# LLM Provider (Google AI Studio — get a free key at https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.5-flash

# Application
LOG_LEVEL=INFO
APP_NAME=Restaurant Recommendation API
DEBUG=false

# LLM tuning
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3

# Recommendation pipeline
MIN_CANDIDATES=10
MAX_CANDIDATES=50
DEFAULT_TOP_K=5

# Dataset
HF_DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation
